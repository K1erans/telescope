#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: gacp \"commit message\"" >&2
  exit 1
}

if [[ $# -lt 1 ]]; then
  usage
fi

message="$*"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "gacp: not inside a git repository" >&2
  exit 1
fi

git add -A
git commit -m "$message"
git push
